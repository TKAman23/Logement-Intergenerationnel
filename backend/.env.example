# ============================================================
# Backend Environment Variables — copy to .env and fill in
# ============================================================

# --- Firebase Service Account ---
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then either paste the JSON path OR paste the values individually below.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# --- CORS Origins ---
# Comma-separated list of allowed frontend origins
# For local dev: http://localhost:5173
# For production: your Firebase Hosting URL
ALLOWED_ORIGINS=http://localhost:5173,https://YOUR-PROJECT.web.app

# --- App Settings ---
APP_ENV=development             # "development" or "production"
LOG_LEVEL=info

# --- HuggingFace Cache (optional) ---
# Where to cache downloaded models. Defaults to ~/.cache/huggingface
# TRANSFORMERS_CACHE=/path/to/model/cache
